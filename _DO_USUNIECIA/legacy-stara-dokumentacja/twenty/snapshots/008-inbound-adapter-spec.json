{
  "snapshotVersion": "008",
  "exportedAt": "2026-05-26T08:55:00Z",
  "description": "Inbound adapter create_lead: specyfikacja API + test VERIFIED. Stape/Sortownia POSTuje do Twenty GraphQL API, tworzac Person + Opportunity + Note.",
  "adapterName": "crm:twenty_create_deal",
  "livesIn": "Stape (Sortownia Custom Code w sGTM)",
  "apiEndpoint": "https://api.twenty.com/graphql",
  "authMethod": "Bearer API_KEY",
  "steps": [
    {
      "order": 1,
      "action": "createPerson",
      "fields": {
        "name.firstName": "from biz_name (first word)",
        "name.lastName": "from biz_name (remaining words)",
        "emails.primaryEmail": "from biz_email",
        "phones.primaryPhoneNumber": "from biz_phone"
      },
      "note": "idOid is NOT on Person object, only on Opportunity"
    },
    {
      "order": 2,
      "action": "createOpportunity",
      "fields": {
        "name": "generated from biz_product (e.g. 'Strona Internetowa — [company]')",
        "stage": "NEW (hardcoded)",
        "idOid": "from id_oid (ULID from Stape)",
        "bizProduct": "from biz_product (uppercase: WEB, SEO, etc.)",
        "bizSource": "from biz_source (uppercase: GOOGLE_ADS, FORM, etc.)",
        "pointOfContactId": "Person ID from step 1"
      }
    },
    {
      "order": 3,
      "action": "createNote",
      "condition": "only if biz_message_content is not empty",
      "fields": {
        "title": "'Pierwsza wiadomość — [biz_product]'",
        "bodyV2.markdown": "from biz_message_content"
      }
    },
    {
      "order": 4,
      "action": "createNoteTarget (x2)",
      "links": [
        "noteId → targetOpportunityId (Opportunity from step 2)",
        "noteId → targetPersonId (Person from step 1)"
      ]
    }
  ],
